{
  "name": "octopus-r2",
  "version": "0.3.9",
  "description": "Private game tools suite for a friend group",
  "author": "CozyArio",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:publish": "npm run build && electron-builder --win nsis portable -p always",
    "release:local": "powershell -ExecutionPolicy Bypass -File scripts/release-local.ps1",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "vdf-parser": "^1.2.1",
    "winreg": "^1.2.4"
  },
  "devDependencies": {
    "@catppuccin/tailwindcss": "^0.1.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/winreg": "^1.2.36",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lucide-react": "^0.395.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "zustand": "^4.5.4"
  },
  "build": {
    "appId": "com.cozyario.octopusr2",
    "productName": "Octopus-R2",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "icons/**/*",
      "package.json",
      "CHANGELOG.md"
    ],
    "win": {
      "icon": "icons/octopus.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "CozyArio",
        "repo": "Octopus-R2"
      }
    ]
  }
}
